    <title>{% block titulo %}Título por defecto{% endblock %}</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/estilos.css">
    {% block css %}{% endblock %}
</head>
