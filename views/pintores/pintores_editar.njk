{% extends "base.njk" %}

{% block titulo %}Editar Pintor{% endblock %}

{% block contenido %}
    <h1>Editar Pintor</h1>

    {% if errors %}
        <div class="alert alert-danger">
            <ul>
                {% for error in errors %}
                    <li>{{ error.msg }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form action="/pintores/{{ pintor._id }}" method="POST" class="mt-4" style="max-width: 500px;">
        <input type="hidden" name="_method" value="put">
        <div class="mb-3">
            <label for="nombre" class="form-label">Nombre:</label>
            <input type="text" id="nombre" name="nombre" value="{{ pintor.nombre }}" class="form-control" required>
        </div>

        <div class="mb-3">
            <label for="estiloArtistico" class="form-label">Estilo Artístico:</label>
            <select id="estiloArtistico" name="estiloArtistico" class="form-select" required>
                <option value="Impresionismo" {% if pintor.estiloArtistico == 'Impresionismo' %}selected{% endif %}>Impresionismo</option>
                <option value="Realismo" {% if pintor.estiloArtistico == 'Realismo' %}selected{% endif %}>Realismo</option>
                <option value="Expresionismo" {% if pintor.estiloArtistico == 'Expresionismo' %}selected{% endif %}>Expresionismo</option>
                <option value="Cubismo" {% if pintor.estiloArtistico == 'Cubismo' %}selected{% endif %}>Cubismo</option>
                <option value="Surrealismo" {% if pintor.estiloArtistico == 'Surrealismo' %}selected{% endif %}>Surrealismo</option>
                <option value="Abstracto" {% if pintor.estiloArtistico == 'Abstracto' %}selected{% endif %}>Abstracto</option>
                <option value="Renacimiento" {% if pintor.estiloArtistico == 'Renacimiento' %}selected{% endif %}>Renacimiento</option>
                <option value="Otro" {% if pintor.estiloArtistico == 'Otro' %}selected{% endif %}>Otro</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="fechaNacimiento" class="form-label">Fecha de Nacimiento:</label>
            <input type="text" id="fechaNacimiento" name="fechaNacimiento" value="{{ pintor.fechaNacimiento }}" class="form-control" required>
        </div>

        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    </form>
{% endblock %}
